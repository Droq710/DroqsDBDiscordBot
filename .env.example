DISCORD_TOKEN=your-discord-bot-token
DISCORD_CLIENT_ID=your-discord-application-client-id
DISCORD_GUILD_ID=your-test-guild-id

LOG_LEVEL=info
DROQSDB_API_BASE_URL=https://droqsdb.com/api/public/v1
DROQSDB_WEB_BASE_URL=https://droqsdb.com
API_CACHE_TTL_MS=30000
API_CACHE_STALE_TTL_MS=120000
DROQSDB_API_TIMEOUT_MS=8000
ALERT_CHECK_INTERVAL_MS=300000
COMMAND_USER_RATE_LIMIT_WINDOW_MS=10000
COMMAND_USER_RATE_LIMIT_MAX=5
COMMAND_GUILD_RATE_LIMIT_WINDOW_MS=10000
COMMAND_GUILD_RATE_LIMIT_MAX=20

AUTOPOST_CRON=0 * * * *
AUTOPOST_TIMEZONE=America/Chicago
AUTOPOST_DB_FILE=./data/autopost.sqlite
# Optional legacy JSON source for one-time migration from the single-server MVP:
AUTOPOST_DATA_FILE=./data/autopost-config.json
